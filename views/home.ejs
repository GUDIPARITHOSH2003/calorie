<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Calorie Tracker</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        :root {
            --bg-color: #0f172a;
            --surface-color: #1e293b;
            --surface-hover: #334155;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --accent: #3b82f6;
            --accent-hover: #60a5fa;
            --danger: #ef4444;
            --danger-hover: #f87171;
            --success: #10b981;
            --border-color: #334155;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background-image: 
                radial-gradient(at 0% 0%, rgba(59, 130, 246, 0.15), transparent 50%),
                radial-gradient(at 100% 100%, rgba(139, 92, 246, 0.15), transparent 50%);
            background-attachment: fixed;
            display: flex;
            flex-direction: column;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 5%;
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .navbar h1 {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(to right, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }

        .nav-links {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .nav-links a {
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            transition: all 0.3s ease;
        }

        .nav-links a:hover {
            background: var(--surface-hover);
        }

        .nav-links a.logout-btn {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .nav-links a.logout-btn:hover {
            background: var(--danger);
            color: white;
        }

        /* Main Container */
        .container {
            max-width: 1000px;
            margin: 2rem auto;
            padding: 0 1.5rem;
            width: 100%;
            flex: 1;
            display: grid;
            gap: 2rem;
            grid-template-columns: 1fr;
        }

        @media (min-width: 768px) {
            .container {
                grid-template-columns: 1fr 1fr;
            }
            .stats-section {
                grid-column: 1 / -1;
            }
        }

        /* Card Style */
        .card {
            background: var(--surface-color);
            border-radius: 1rem;
            padding: 2rem;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1rem;
        }

        .card-header h2 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }

        /* Form */
        form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .input-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .input-group.full {
            grid-template-columns: 1fr;
        }

        input {
            width: 100%;
            padding: 0.75rem 1rem;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            color: var(--text-primary);
            font-size: 0.95rem;
            transition: border-color 0.3s ease;
        }

        input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
        }

        input::placeholder {
            color: var(--text-secondary);
        }

        button {
            padding: 0.875rem 1.5rem;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 0.5rem;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            margin-top: 0.5rem;
        }

        button:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 1rem;
        }

        .stat-box {
            background: rgba(15, 23, 42, 0.5);
            padding: 1.5rem;
            border-radius: 0.75rem;
            border: 1px solid var(--border-color);
            text-align: center;
        }

        .stat-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .stat-value.calories { color: var(--accent); }
        .stat-value.protein { color: #8b5cf6; }
        .stat-value.carbs { color: #f59e0b; }
        .stat-value.fat { color: #ef4444; }
        .stat-value.fiber { color: #10b981; }

        .btn-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            border: 1px solid var(--accent);
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            transition: all 0.3s ease;
        }

        .btn-link:hover {
            background: var(--accent);
            color: white;
        }

    </style>
</head>

<body>
    <nav class="navbar">
        <h1>Calorie Tracker</h1>
        <div class="nav-links">
            <a href="/user/profile">Profile</a>
            <a href="/auth/logout" class="logout-btn">Logout</a>
        </div>
    </nav>

    <div class="container">
        <!-- Stats Section -->
        <div class="card stats-section">
            <div class="card-header">
                <h2>Today's Summary</h2>
                <a href="/dashboard/today-list" class="btn-link">View Today items</a>
            </div>
            <div id="food-container">
                <!-- Data will be loaded here -->
            </div>
        </div>

        <!-- Add Food Form -->
        <div class="card">
            <div class="card-header">
                <h2>Add New Item</h2>
            </div>
            <form action="/dashboard/add-item" method="post">
                <div class="input-group full">
                    <input type="text" name="itemName" placeholder="Item Name" required>
                </div>
                <div class="input-group">
                    <input type="text" name="quantity" placeholder="Quantity">
                    <input type="number" name="calories" placeholder="Calories">
                </div>
                <div class="input-group">
                    <input type="number" name="protein" placeholder="Protein">
                    <input type="number" name="carbs" placeholder="Carbs">
                </div>
                <div class="input-group">
                    <input type="number" name="fiber" placeholder="Fiber">
                    <input type="number" name="fat" placeholder="Fat">
                </div>
                <button type="submit">Add Item</button>
            </form>
        </div>
    </div>

    <script>
        async function loadTodayItems(){
            try{
                const res=await axios.get('/dashboard/today-items',{
                    withCredentials:true
                })
                const data=res.data
                const container=document.getElementById('food-container')
                container.innerHTML=''
                let result={
                    calories:0,
                    protein:0,
                    carbs:0,
                    fiber:0,
                    fat:0  
                }
                if(data.length===0){
                    container.innerHTML=`
                        <div class="stats-grid">
                            <div class="stat-box">
                                <div class="stat-label">Calories</div>
                                <div class="stat-value calories">${result.calories}</div>
                            </div>
                            <div class="stat-box">
                                <div class="stat-label">Protein</div>
                                <div class="stat-value protein">${result.protein}</div>
                            </div>
                            <div class="stat-box">
                                <div class="stat-label">Carbs</div>
                                <div class="stat-value carbs">${result.carbs}</div>
                            </div>
                            <div class="stat-box">
                                <div class="stat-label">Fiber</div>
                                <div class="stat-value fiber">${result.fiber}</div>
                            </div>
                            <div class="stat-box">
                                <div class="stat-label">Fat</div>
                                <div class="stat-value fat">${result.fat}</div>
                            </div>
                        </div>
                    `
                    return
                }
                data.forEach((item)=>{
                    result.calories+=item.calories
                    result.protein+=item.protein
                    result.carbs+=item.carbs
                    result.fiber+=item.fiber
                    result.fat+=item.fat
                })
                container.innerHTML=`
                    <div class="stats-grid">
                        <div class="stat-box">
                            <div class="stat-label">Calories</div>
                            <div class="stat-value calories">${result.calories}</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Protein</div>
                            <div class="stat-value protein">${result.protein}</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Carbs</div>
                            <div class="stat-value carbs">${result.carbs}</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Fiber</div>
                            <div class="stat-value fiber">${result.fiber}</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">Fat</div>
                            <div class="stat-value fat">${result.fat}</div>
                        </div>
                    </div>
                `
            }catch(err){
                console.log(err)
            }
        }
        loadTodayItems()
    </script>
</body>
</html>