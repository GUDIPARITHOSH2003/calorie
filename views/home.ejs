<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>

    <style>
        :root {
            --bg-color: #0f172a;
            --accent: #3b82f6;
            --accent-hover: #60a5fa;
        }

        body {
            background-color: var(--bg-color);
            color: white;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 2rem;

            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;

            /* ✅ same gradient background */
            background-image: 
                radial-gradient(at 0% 0%, rgba(59, 130, 246, 0.15), transparent 50%),
                radial-gradient(at 100% 100%, rgba(139, 92, 246, 0.15), transparent 50%);
        }

        /* ✅ Gradient heading like profile page */
        h1 {
            font-size: 2rem;
            font-weight: 600;
            background: linear-gradient(to right, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }

        /* ✅ Button style */
        a {
            display: inline-block;
            margin-top: 2rem;
            padding: 0.75rem 1.5rem;
            background: var(--accent);
            color: white;
            text-decoration: none;
            border-radius: 0.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        a:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body>
    <h1>Home Page</h1>
    <a href="/user/profile">Profile</a>
    <h2>Todays Amount</h2>
    <div id="food-container"></div>
    <form action="/dashboard/add-item" method="post">
    <div>
        <input type="text" name="itemName" placeholder="itemName">
        <input type="number" name="calories" placeholder="calories">
        <input type="number" name="protein" placeholder="protein">
        <input type="number" name="carbs" placeholder="carbs">
        <input type="number" name="fiber" placeholder="fiber">
        <input type="number" name="fat" placeholder="fat">
        <button type="submit">Add Item</button>
    </div>
    </form>
    <script>
        async function loadTodayItems(){
            try{
                const res=await axios.get('/dashboard/today-items',{
                    withCredentials:true
                })
                const data=res.data
                const container=document.getElementById('food-container')
                container.innerHTML=''
                result={
                    calories:0,
                    protein:0,
                    carbs:0,
                    fiber:0,
                    fat:0  
                }
                if(data.length===0){
                    container.innerHTML=`
                        <div class="card">
                            <p>Calories: ${result.calories}</p>
                            <p>Protein: ${result.protein}</p>
                            <p>Carbs: ${result.carbs}</p>
                            <p>Fiber: ${result.fiber}</p>
                            <p>Fat: ${result.fat}</p>
                        </div>
                    `
                    return
                }
                data.forEach((item)=>{
                    result.calories+=item.calories
                    result.protein+=item.protein
                    result.carbs+=item.carbs
                    result.fiber+=item.fiber
                    result.fat+=item.fat
                })
                container.innerHTML=`
                    <div class="card">
                            <p>Calories: ${result.calories}</p>
                            <p>Protein: ${result.protein}</p>
                            <p>Carbs: ${result.carbs}</p>
                            <p>Fiber: ${result.fiber}</p>
                            <p>Fat: ${result.fat}</p>
                    </div>
                `
            }catch(err){
                console.log(err)
            }
        }
        loadTodayItems()
    </script>
</body>
</html>