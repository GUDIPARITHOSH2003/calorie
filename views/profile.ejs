<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --text-primary: #f8fafc;
            --text-secondary: #cbd5e1;
            --accent: #3b82f6;
            --accent-hover: #60a5fa;
            --border: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: 'Inter', -apple-system, blinkmacsystemfont, sans-serif;
            margin: 0;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            background-image: 
                radial-gradient(at 0% 0%, rgba(59, 130, 246, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(139, 92, 246, 0.15) 0px, transparent 50%);
        }

        h1, h2, h3 {
            margin-bottom: 1.5rem;
            font-weight: 600;
            background: linear-gradient(to right, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }

        div, form {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 2rem;
            margin-bottom: 1.5rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            box-sizing: border-box;
        }

        input {
            width: 100%;
            padding: 0.75rem 1rem;
            margin-bottom: 1rem;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            border-radius: 0.5rem;
            color: var(--text-primary);
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
        }

        button {
            width: 100%;
            padding: 0.75rem 1rem;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 0.5rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 1rem;
        }

        button:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        a {
            display: inline-block;
            color: var(--accent);
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s ease;
            text-align: center;
            width: 100%;
            margin-top: 0.5rem;
        }

        a:hover {
            color: var(--accent-hover);
        }
    </style>
</head>
<body>
    <h2>Profile Page</h2>
    <a href="/user">Home</a>
    <div>
        <form action="/user/change-email" method="post">
            <h3>Email : <%=user.email%></h3>
            <input type="text" name="email" placeholder="new email">
            <button type="submit">Change email</button>
        </form>
    </div>
    <div>
        <form action="/user/change-fields" method="post">
            <h3>Age : <%=user.age%></h3>
            <h3>Weight : <%=user.weight%></h3>
            <h3>Height : <%=user.height%></h3>
            <input type="text" name="age" placeholder="new age" value= <%=user.age%>>
            <input type="text" name="weight" placeholder="new weight" value= <%=user.weight%>>
            <input type="text" name="height" placeholder="new height" value= <%=user.height%>>
            <select name="goal">
                <option value="loss" <%= user.goal === 'loss' ? 'selected' : '' %>>Weight Loss</option>
                <option value="maintain" <%= user.goal === 'maintain' ? 'selected' : '' %>>Maintain</option>
                <option value="gain" <%= user.goal === 'gain' ? 'selected' : '' %>>Weight Gain</option>
            </select>
            <select name="activityLevel">
                <option value="sedentary" <%= user.activityLevel === 'sedentary' ? 'selected' : '' %>>Sedentary (no exercise)</option>
                <option value="light" <%= user.activityLevel === 'light' ? 'selected' : '' %>>Light (1–3 days/week)</option>
                <option value="moderate" <%= user.activityLevel === 'moderate' ? 'selected' : '' %>>Moderate (3–5 days/week)</option>
                <option value="active" <%= user.activityLevel === 'active' ? 'selected' : '' %>>Active (6–7 days/week)</option>
                <option value="very_active" <%= user.activityLevel === 'very_active' ? 'selected' : '' %>>Very Active</option>
            </select>
            <select name="gender">
                <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Male</option>
                <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
            </select>
            <button type="submit">Change Data</button>
        </form>
    </div>
    <div>
        <%if(user.dailyCalories){%>
            <h3>Daily calories : <%=user.dailyCalories%></h3>
        <%}else{%>
            <a href="/user/calculate-calories">Calculate Calories</a>
            <h3>Daily calories : <%=user.dailyCalories%></h3>
        <%}%>
    </div>
</body>
</html>